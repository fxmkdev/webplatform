{
  "name": "@fxmk/cms-plugin",
  "version": "0.0.0-unknown",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fxmkdev/webplatform.git"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm copyfiles && pnpm build:types && pnpm build:swc",
    "build:swc": "swc ./src -d ./dist --config-file .swcrc --strip-leading-paths",
    "build:types": "tsc --outDir dist --rootDir ./src",
    "clean": "rimraf --glob dist \"*.tsbuildinfo\"",
    "copyfiles": "copyfiles -u 1 \"src/**/*.{html,css,scss,ttf,woff,woff2,eot,svg,jpg,png,json}\" dist/",
    "lint": "eslint src",
    "lint:fix": "eslint ./src --fix",
    "test": "pnpm test:int && pnpm test:e2e",
    "test:e2e": "playwright test",
    "test:int": "vitest",
    "check-format": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@payloadcms/eslint-config": "3.28.0",
    "@swc-node/register": "1.10.9",
    "@swc/cli": "0.8.1",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.12.4",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "bson": "^6.10.4",
    "copyfiles": "2.4.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.23.0",
    "eslint-config-next": "16.2.6",
    "jsdom": "26.1.0",
    "next": "16.2.6",
    "payload": "3.84.1",
    "prettier": "^3.8.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "rimraf": "6.1.3",
    "typescript": "6.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.6",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/ui": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/storage-s3": "3.84.1"
  },
  "peerDependencies": {
    "@payloadcms/db-mongodb": "^3.84.1",
    "bson": "^6.10.4",
    "jsdom": "26.1.0",
    "next": ">=16.2.2 <17.0.0",
    "payload": "^3.84.1",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "@payloadcms/ui": "^3.84.1",
    "@payloadcms/richtext-lexical": "^3.84.1",
    "@payloadcms/storage-s3": "^3.84.1"
  },
  "dependencies": {
    "@payloadcms/translations": "3.84.1",
    "deepl-node": "^1.27.0",
    "openai": "^6.38.0",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": "^9 || ^10"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "import": "./dist/components/client/index.js",
      "types": "./dist/components/client/index.d.ts",
      "default": "./dist/components/client/index.js"
    },
    "./rsc": {
      "import": "./dist/components/rsc/index.js",
      "types": "./dist/components/rsc/index.d.ts",
      "default": "./dist/components/rsc/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "registry": "https://registry.npmjs.org/"
}
