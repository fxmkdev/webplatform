{
  "name": "@fxmk/cms-example",
  "private": true,
  "version": "0.0.0-unknown",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build --webpack",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --webpack",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev --webpack",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "check-format": "prettier --check ."
  },
  "dependencies": {
    "@fxmk/cms-plugin": "workspace:*",
    "@fxmk/common": "workspace:*",
    "@payloadcms/db-mongodb": "3.84.1",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/storage-s3": "3.84.1",
    "@payloadcms/ui": "3.84.1",
    "cross-env": "^10.1.0",
    "next": "16.2.6",
    "payload": "3.84.1",
    "react": "19.2.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.8.3",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": "^9 || ^10"
  }
}
